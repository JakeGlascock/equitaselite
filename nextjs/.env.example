# Copy to .env.local and fill in values from Terraform outputs
# Never commit .env.local

AWS_REGION=us-east-1

# Cognito — from: terraform output cognito_user_pool_id / cognito_client_id
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_DOMAIN=https://equitaselite-prod.auth.us-east-1.amazoncognito.com

# Database — from: terraform output rds_endpoint
DB_HOST=equitaselite-prod.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=equitaselite
DB_USER=equitaselite_admin
DB_PASSWORD=                  # injected at runtime via Secrets Manager; set locally for dev

# S3 — from: terraform output documents_bucket
DOCUMENTS_BUCKET=equitaselite-prod-documents

# App
NEXT_PUBLIC_APP_URL=https://equitaselite.com

# Admin — comma-separated emails granted access to /admin
ADMIN_EMAILS=jake@equitaselite.com
